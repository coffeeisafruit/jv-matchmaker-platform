# Django Configuration
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# Database Configuration
# For production, use PostgreSQL (Supabase or other provider)
DATABASE_URL=postgresql://user:password@host:port/database
DIRECT_DATABASE_URL=postgresql://user:password@host:port/database

# Supabase Configuration (optional - for future use)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# AI API Keys
# At least one AI API key is required for the platform to function
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key
GEMINI_API_KEY=your-gemini-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key

# Clay Integration (optional - for webhook integration)
CLAY_WEBHOOK_SECRET=your-clay-webhook-secret

# Sales / Pitch Page (code-gated landing page)
SALES_PAGE_PASSWORD=your-secret-access-code

# Email Delivery (Resend SMTP)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=587
EMAIL_HOST_USER=resend
EMAIL_HOST_PASSWORD=re_your_resend_api_key
DEFAULT_FROM_EMAIL=reports@jvmatches.com

# Prefect Cloud
PREFECT_API_URL=https://api.prefect.cloud/api/accounts/YOUR_ACCT/workspaces/YOUR_WS
PREFECT_API_KEY=pnu_your_prefect_cloud_api_key

# Alerting
ADMIN_EMAIL=joe@example.com
ALERT_EMAIL=joe@example.com
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
